# Copy to ../.secrets (parent AGENT_JOURNAL folder) or set as env vars.
# Do NOT commit real values.

# --- App credentials (from X Developer Portal → your app → Keys and tokens) ---
X_API_CONSUMER_KEY=
X_API_SECRET_KEY=
X_API_BEARER_TOKEN=

# OAuth 2.0 only (User authentication settings → Client ID / Client Secret)
X_API_CLIENT_ID=
X_API_CLIENT_SECRET=

# --- User credentials (produced by oauth1_authorize.py — @rep_of_LLetters) ---
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_SCREEN_NAME=rep_of_LLetters

# OAuth 2.0 user tokens (produced by oauth2_authorize.py — optional path)
X_OAUTH2_ACCESS_TOKEN=
X_OAUTH2_REFRESH_TOKEN=
