#!/usr/bin/env bash
# `dorm` shim — forwards to dorm.py with its venv's python when available,
# falling back to the ambient python3.
#
# Install: sudo ln -sf "$(pwd)/dorm" /usr/local/bin/dorm
# (or symlink into any directory that's in $PATH)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
VENV_PY="$SCRIPT_DIR/.venv/bin/python3"
if [[ -x "$VENV_PY" ]]; then
  exec "$VENV_PY" "$SCRIPT_DIR/dorm.py" "$@"
fi
exec python3 "$SCRIPT_DIR/dorm.py" "$@"
